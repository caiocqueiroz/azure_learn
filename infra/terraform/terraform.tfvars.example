location            = "eastus"
resource_group_name = "rg-taskflow-study"
environment_name    = "cae-taskflow-study"
acr_name            = "taskflowacrstudy001"
image_tag           = "latest"
enable_dapr         = true
worker_interval_ms  = "10000"
taskflow_api_key    = "replace-with-a-study-secret"

container_apps = {
  frontend-web = { cpu = 0.5, memory = "1Gi", min_replicas = 1, max_replicas = 3 }
  api-gateway = { cpu = 0.25, memory = "0.5Gi", min_replicas = 0, max_replicas = 5 }
  task-service = { cpu = 0.25, memory = "0.5Gi", min_replicas = 0, max_replicas = 5 }
  user-service = { cpu = 0.25, memory = "0.5Gi", min_replicas = 0, max_replicas = 3 }
  notification-service = { cpu = 0.25, memory = "0.5Gi", min_replicas = 0, max_replicas = 3 }
  worker-service = { cpu = 0.25, memory = "0.5Gi", min_replicas = 0, max_replicas = 2 }
}
